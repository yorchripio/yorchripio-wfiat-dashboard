// Prisma schema for wFIAT Dashboard
// Database: Supabase (PostgreSQL). Usuarios y snapshots viven acá.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── ENUMS ───

enum UserRole {
  ADMIN
  TRADER
  VIEWER
}

/// Tipo de instrumento de colateral (igual que en el sheet)
enum InstrumentoTipo {
  FCI
  Cuenta_Remunerada
  A_la_Vista
  CDB
}

// ─── MODELS ───

model User {
  id           String    @id @default(uuid())
  email        String    @unique
  passwordHash String    @map("password_hash")
  name         String
  role         UserRole  @default(VIEWER)
  totpSecret   String?   @map("totp_secret")   // Encrypted with AES-256-GCM
  totpEnabled  Boolean   @default(false) @map("totp_enabled")
  isActive     Boolean   @default(true) @map("is_active")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  @@map("users")
}

/// Snapshot diario (o por ejecución) del supply total por chain para un asset (wARS, etc.)
model SupplySnapshot {
  id          String   @id @default(uuid())
  asset       String   // "wARS", "wBRL", etc.
  total       Decimal  @db.Decimal(28, 2)
  chainsJson  Json     @map("chains_json")  // { ethereum: { supply, supplyRaw, success?, error? }, worldchain, base }
  snapshotAt  DateTime @map("snapshot_at")   // Fecha/hora del snapshot (normalizado a día si es diario)
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([asset, snapshotAt])
  @@index([snapshotAt])
  @@map("supply_snapshots")
}

/// Snapshot del colateral total e instrumentos para un asset en un momento dado
model CollateralSnapshot {
  id                 String   @id @default(uuid())
  asset              String   // "wARS", etc.
  total              Decimal  @db.Decimal(28, 2)
  instrumentosJson   Json     @map("instrumentos_json")  // Array de InstrumentoColateral
  rendimientoCartera Decimal? @db.Decimal(10, 4) @map("rendimiento_cartera")
  snapshotAt         DateTime @map("snapshot_at")
  createdAt          DateTime @default(now()) @map("created_at")

  @@index([asset, snapshotAt])
  @@index([snapshotAt])
  @@map("collateral_snapshots")
}

/// Configuración de cada tipo de instrumento (si genera rendimiento, label, etc.)
model InstrumentoConfig {
  id                String          @id @default(uuid())
  tipo              InstrumentoTipo @unique
  label             String
  generaRendimiento Boolean         @default(false) @map("genera_rendimiento")
  createdAt         DateTime        @default(now()) @map("created_at")
  updatedAt         DateTime        @updatedAt @map("updated_at")

  @@map("instrumento_configs")
}

/// Rendimiento diario de la cartera (importado del Sheet fila 37, o calculado).
/// Este es el % de retorno diario del portafolio completo.
model RendimientoHistorico {
  id          String   @id @default(uuid())
  asset       String   @default("wARS")
  fecha       DateTime @db.Date
  rendimiento Decimal  @db.Decimal(12, 6) @map("rendimiento")
  createdAt   DateTime @default(now()) @map("created_at")

  @@unique([asset, fecha])
  @@index([asset, fecha])
  @@map("rendimiento_historico")
}

/// Línea de colateral cargada desde la app (reemplazo futuro del Google Sheet).
/// valorTotal = cantidadCuotasPartes * valorCuotaparte. Rendimiento a futuro se puede calcular o cargar.
model CollateralAllocation {
  id                   String          @id @default(uuid())
  asset                String          @default("wARS")
  tipo                 InstrumentoTipo
  nombre               String          // ej. "Adcap Ahorro Pesos - Clase B"
  entidad              String?        // ej. "Banco Comercio"
  cantidadCuotasPartes  Decimal         @db.Decimal(28, 6) @map("cantidad_cuotas_partes")
  valorCuotaparte       Decimal         @db.Decimal(28, 6) @map("valor_cuotaparte")
  fecha                 DateTime        @db.Date @map("fecha")  // Fecha del dato
  rendimientoDiario     Decimal?        @db.Decimal(10, 4) @map("rendimiento_diario")  // Opcional; a futuro calculado
  activo                Boolean         @default(true) @map("activo")
  createdAt             DateTime        @default(now()) @map("created_at")
  updatedAt             DateTime        @updatedAt @map("updated_at")

  @@index([asset, fecha])
  @@index([fecha])
  @@map("collateral_allocations")
}

/// Posición CDB parseada del PDF de Renda Fixa (Banco Genial).
/// Cada fila es un CDB individual con su valor actual.
model WbrlCdbPosition {
  id              String   @id @default(uuid())
  fechaPosicao    DateTime @db.Date @map("fecha_posicao")    // Fecha del reporte
  fechaInicio     DateTime @db.Date @map("fecha_inicio")     // Fecha inicio del CDB
  fechaVencimento DateTime @db.Date @map("fecha_vencimento") // Fecha vencimiento
  capitalInicial  Decimal  @db.Decimal(18, 2) @map("capital_inicial")
  valorBruto      Decimal  @db.Decimal(18, 2) @map("valor_bruto")
  valorLiquido    Decimal  @db.Decimal(18, 2) @map("valor_liquido")
  ir              Decimal  @db.Decimal(18, 2)
  indexador       String   @default("CDICETIP")
  pctIndexador    Decimal  @db.Decimal(5, 1) @map("pct_indexador") // 99.0
  emisor          String   @default("BANCO GENIAL S.A.")
  esColateral     Boolean  @default(true) @map("es_colateral")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@index([fechaPosicao])
  @@index([esColateral, fechaPosicao])
  @@map("wbrl_cdb_positions")
}

/// Movimientos del extracto de conta corrente (Banco Genial).
model WbrlExtrato {
  id          String   @id @default(uuid())
  fecha       DateTime @db.Date
  descripcion String
  valor       Decimal  @db.Decimal(18, 2)
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([fecha])
  @@map("wbrl_extracto")
}

/// Posición mensual del fondo REGIO1 (Banregio) para wMXN.
/// Cada fila es un snapshot mensual del estado de cuenta.
model WmxnFundPosition {
  id                 String   @id @default(uuid())
  fechaReporte       DateTime @db.Date @map("fecha_reporte")      // Fin de periodo
  periodoInicio      DateTime @db.Date @map("periodo_inicio")
  periodoFin         DateTime @db.Date @map("periodo_fin")
  fondo              String   @default("REGIO1")
  serie              String   @default("M")
  titulosInicio      Int      @map("titulos_inicio")
  titulosCierre      Int      @map("titulos_cierre")
  precioValuacion    Decimal  @db.Decimal(12, 6) @map("precio_valuacion")
  valorCartera       Decimal  @db.Decimal(18, 2) @map("valor_cartera")
  movimientosNetos   Decimal  @db.Decimal(18, 2) @map("movimientos_netos")
  plusvalia           Decimal  @db.Decimal(18, 2)
  rendimientoAnual   Decimal? @db.Decimal(6, 2) @map("rendimiento_anual")
  rendimientoMensual Decimal? @db.Decimal(6, 2) @map("rendimiento_mensual")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  @@index([fechaReporte])
  @@map("wmxn_fund_positions")
}

/// Snapshot mensual de la cuenta de ahorro Finandina para wCOP.
/// Resumen derivado del CSV extracto bancario.
model WcopAccountSnapshot {
  id              String   @id @default(uuid())
  fechaCorte      DateTime @db.Date @map("fecha_corte")       // Fecha del último movimiento
  periodoInicio   DateTime @db.Date @map("periodo_inicio")
  periodoFin      DateTime @db.Date @map("periodo_fin")
  saldoFinal      Decimal  @db.Decimal(18, 2) @map("saldo_final")
  capitalWcop     Decimal  @db.Decimal(18, 2) @map("capital_wcop")    // Total depósitos WCOP identificados
  rendimientos    Decimal  @db.Decimal(18, 2)                         // Total intereses ganados
  retirosMM       Decimal  @db.Decimal(18, 2) @map("retiros_mm")     // Total retiros Market Making
  depositosMM     Decimal  @db.Decimal(18, 2) @map("depositos_mm")   // Total depósitos MM (Koywe)
  impuestos       Decimal  @db.Decimal(18, 2)                         // Gravamen 4x1000
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@index([fechaCorte])
  @@map("wcop_account_snapshots")
}

/// Cache de pools de GeckoTerminal. Se actualiza cada 15 min vía cron.
model GeckoPoolCache {
  id          String   @id // poolAddress
  networkId   String   @map("network_id")
  label       String
  token       String
  dataJson    Json     @map("data_json") // Full GeckoPool object
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([token])
  @@map("gecko_pool_cache")
}

/// Evento de emisión/rescate de cuotapartes del portfolio wARS.
/// Cada suscripción/rescate de FCI genera un evento que cambia las cuotapartes totales sin afectar el VCP.
model CuotaparteEvent {
  id          String   @id @default(uuid())
  asset       String   @default("wARS")
  fecha       DateTime @db.Date
  tipo        String   // "SUSCRIPCION" | "RESCATE"
  montoARS    Decimal  @db.Decimal(28, 2) @map("monto_ars")
  vcpFCI      Decimal  @db.Decimal(28, 6) @map("vcp_fci")       // VCP del CAFCI en esa fecha
  cuotapartes Decimal  @db.Decimal(28, 6)                        // +suscripción, -rescate
  descripcion String?
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([asset, fecha])
  @@map("cuotaparte_events")
}

/// VCP diario del portfolio. Calculado como patrimonio / cuotapartesTotales.
/// Permite medir rendimiento independiente de flujos de capital.
model PortfolioVCP {
  id                 String   @id @default(uuid())
  asset              String   @default("wARS")
  fecha              DateTime @db.Date
  vcp                Decimal  @db.Decimal(28, 8)   // VCP del portfolio
  cuotapartesTotales Decimal  @db.Decimal(28, 6) @map("cuotapartes_totales")
  patrimonio         Decimal  @db.Decimal(28, 2)   // cuotapartesTotales × vcp
  createdAt          DateTime @default(now()) @map("created_at")

  @@unique([asset, fecha])
  @@index([asset, fecha])
  @@map("portfolio_vcp")
}

/// Snapshot mensual de la cuenta corriente BCI para wCLP.
/// Resumen derivado del XLSX extracto bancario (MOVCTACTE).
model WclpAccountSnapshot {
  id              String   @id @default(uuid())
  fechaCorte      DateTime @db.Date @map("fecha_corte")
  periodoInicio   DateTime @db.Date @map("periodo_inicio")
  periodoFin      DateTime @db.Date @map("periodo_fin")
  saldoFinal      Decimal  @db.Decimal(18, 2) @map("saldo_final")
  totalAbonos     Decimal  @db.Decimal(18, 2) @map("total_abonos")
  totalCargos     Decimal  @db.Decimal(18, 2) @map("total_cargos")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@index([fechaCorte])
  @@map("wclp_account_snapshots")
}
